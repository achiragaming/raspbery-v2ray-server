# =============================================================================
# .env — single source of truth for all config
# Place at /opt/clash-stack/.env
# =============================================================================

# IPs
PIHOLE_IP=192.168.8.145
CLASH_IP=192.168.8.146
LAN_SUBNET=192.168.8.0/24
LAN_GATEWAY=192.168.8.1
LAN_DNS=192.168.8.1
# Pi-hole
# if you ever change password,make sure to update this and rerun setup.sh and restart the docker containers
PIHOLE_PASSWORD=changeme

# Clash
# if you ever change secret, make sure to update this and rerun setup.sh and restart the docker containers
CLASH_SECRET=changeme

# Timezone
TZ=Asia/Singapore

VPS_PROFILE_NAME=My-VPS-SG
